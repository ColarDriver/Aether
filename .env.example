# Aether environment example
# Copy to .env and fill in credentials.

# Generic OpenAI-compatible endpoint config

# OpenAI provider
OPENAI_API_KEY=
OPENAI_BASE_URL=
AETHER_MODEL=gpt-4o-mini

# Anthropic provider
ANTHROPIC_API_KEY=

# Optional provider-specific keys
CODEX_ACCESS_TOKEN=
NOUS_API_KEY=

# Runtime mode
AETHER_ENV=development
